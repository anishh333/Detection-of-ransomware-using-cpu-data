' ============================================================================
' ██  8. ACTIVITY DIAGRAM — Behavioral
' ============================================================================
@startuml ActivityDiagram
!theme cerulean-outline
skinparam backgroundColor #FAFAFA
skinparam activityBackgroundColor #EFF6FF
skinparam activityBorderColor #1E40AF
skinparam activityDiamondBackgroundColor #FEF3C7
skinparam shadowing true
skinparam roundCorner 10

title <b>Activity Diagram</b>\nEnd-to-End Ransomware Detection Pipeline

start

partition "Data Preparation" #E0F2FE {
    :Load configuration\n(HPC_EVENTS, IO_EVENTS, STAT_FEATURES);
    if (Dataset exists?) then (yes)
        :Load ransomware_dataset.csv;
    else (no)
        :Generate synthetic traces\n(22 ransomware + 4 benign)\n× 6 workloads × 7 rounds;
        :Compute statistical features\n(mean, median, std, IQR)\nper HPC & I/O event;
        :Save dataset to CSV;
    endif
}

partition "Model Training" #F0FDF4 {
    :Split data → Train (5 rounds)\n+ Test (2 rounds);
    :Apply StandardScaler\nnormalization;

    fork
        :Train Random Forest;
    fork again
        :Train SVM (RBF);
    fork again
        :Train Decision Tree;
    fork again
        :Train kNN (k=5);
    fork again
        :Train XGBoost;
    end fork

    :Evaluate all classifiers\n(Balanced Accuracy, F1,\nPrecision, Recall, FPR, FNR);
    :Select best model\n(highest balanced accuracy);
    :Persist best_model.pkl,\nscaler.pkl, model_info.json;
}

partition "Real-Time Detection" #FEF3C7 {
    :Load trained model\ninto SystemMonitor;

    repeat
        :Collect CPU metrics via psutil\n(cpu_percent, cpu_times, cpu_stats);
        :Collect Disk I/O metrics via psutil\n(disk_io_counters);
        :Map raw metrics →\nHPC & I/O event features;
        :Append to sliding-window buffers\n(HPC: 40 samples, I/O: 10 samples);
        :Compute statistical features\nfrom buffer windows;
        :Scale features with\ntrained StandardScaler;
        :Run ML prediction\n→ (label, probability);

        if (prediction == 1 ?) then (Ransomware!)
            #FF6B6B:Scan processes\n(psutil.process_iter);
            :Rank by CPU% + I/O write bytes;
            :Filter out protected\nsystem processes;
            :Identify suspect process\n(name, PID, path, category);
            :Display threat alert\n(color-coded by severity);

            if (User confirms kill?) then (yes)
                :Validate PID & ownership;
                :Terminate process\n(psutil.Process.terminate);
            else (no)
                :Log and continue monitoring;
            endif
        else (Benign)
            :Update dashboard\nwith green status;
        endif

    repeat while (Monitoring active?) is (yes)
}

stop

@enduml


' ============================================================================
' ██  9. STATE CHART DIAGRAM — Behavioral
' ============================================================================
@startuml StateChartDiagram
!theme cerulean-outline
skinparam backgroundColor #FAFAFA
skinparam stateBackgroundColor #EFF6FF
skinparam stateBorderColor #1E40AF
skinparam shadowing true
skinparam roundCorner 10

title <b>State Chart Diagram</b>\nSystemMonitor — Lifecycle States

[*] --> Uninitialized

state Uninitialized #F3F4F6 {
    Uninitialized : No model loaded
    Uninitialized : model_loaded = False
}

Uninitialized --> ModelLoading : __init__() called\n[model files exist]
Uninitialized --> NoModel : __init__() called\n[model files missing]

state NoModel #FEE2E2 {
    NoModel : model = None
    NoModel : scaler = None
    NoModel : model_loaded = False
}

state ModelLoading #FEF3C7 {
    ModelLoading : Loading best_model.pkl
    ModelLoading : Loading scaler.pkl
    ModelLoading : Parsing model_info.json
}

ModelLoading --> Ready : Load successful
ModelLoading --> NoModel : Load failed

NoModel --> TrainingInProgress : /api/train triggered

state TrainingInProgress #FDE68A {
    state "Generating Data" as GenData
    state "Training Classifiers" as TrainCLF
    state "Evaluating Models" as EvalMod
    state "Saving Best Model" as SaveModel

    [*] --> GenData : [no dataset]
    GenData --> TrainCLF : dataset ready
    [*] --> TrainCLF : [dataset exists]
    TrainCLF --> EvalMod : all classifiers trained
    EvalMod --> SaveModel : best model selected
    SaveModel --> [*]
}

TrainingInProgress --> Ready : Training complete\nReload SystemMonitor

state Ready #D1FAE5 {
    Ready : model_loaded = True
    Ready : Awaiting detection request
}

Ready --> Collecting : /api/detect called

state Collecting #DBEAFE {
    Collecting : collect_sample()
    Collecting : Reading CPU & Disk I/O
    Collecting : via psutil
}

Collecting --> Computing : Raw samples buffered

state Computing #E0E7FF {
    Computing : compute_features()
    Computing : mean, median, std, IQR
    Computing : per HPC & I/O event
}

Computing --> Predicting : Features computed

state Predicting #FEF3C7 {
    Predicting : predict(features)
    Predicting : scaler.transform → model.predict
}

Predicting --> ThreatDetected : prediction == 1\n[probability ≥ 0.5]
Predicting --> Safe : prediction == 0

state Safe #D1FAE5 {
    Safe : is_ransomware = False
    Safe : Update dashboard (green)
}

state ThreatDetected #FEE2E2 {
    state "Scanning Processes" as Scan
    state "Ranking Suspects" as Rank
    state "Threat Identified" as Identified

    [*] --> Scan : _identify_threat()
    Scan --> Rank : process list obtained
    Rank --> Identified : highest CPU/IO found
    Identified --> [*]
}

Safe --> Ready : Cycle complete\nReturn result
ThreatDetected --> AwaitingAction : Threat info prepared

state AwaitingAction #FDE68A {
    AwaitingAction : Alert displayed to user
    AwaitingAction : "Stop Threat" button available
}

AwaitingAction --> ProcessTermination : User clicks "Stop Threat"
AwaitingAction --> Ready : User dismisses\nor next cycle

state ProcessTermination #FCA5A5 {
    state "Validating PID" as ValPID
    state "Checking Protected List" as ChkProt
    state "Terminating Process" as TermProc

    [*] --> ValPID
    ValPID --> ChkProt : PID valid
    ChkProt --> TermProc : Not protected
    ChkProt --> [*] : Protected → deny
    TermProc --> [*] : Process killed
}

ProcessTermination --> Ready : Action complete

@enduml
