' ============================================================================
' ██  1. CLASS DIAGRAM — Structural
' ============================================================================
@startuml ClassDiagram
!theme cerulean-outline
skinparam backgroundColor #FAFAFA
skinparam classAttributeIconSize 0
skinparam classFontSize 13
skinparam classHeaderBackgroundColor #2563EB
skinparam classHeaderFontColor #FFFFFF
skinparam classStereotypeFontColor #6B7280
skinparam shadowing true
skinparam roundCorner 12
skinparam linetype ortho

title <b>Class Diagram</b>\nRansomware Detection System — Structural View

package "Web Layer" #E0F2FE {
    class FlaskApp <<Controller>> {
        - app : Flask
        - monitor : SystemMonitor
        __
        + index() : HTML
        + training_page() : HTML
        + monitoring_page() : HTML
        + about_page() : HTML
        + api_system_status() : JSON
        + api_detect() : JSON
        + api_model_info() : JSON
        + api_model_results() : JSON
        + api_train() : JSON
        + api_detection_history() : JSON
        + api_kill_process() : JSON
        + api_hpc_events() : JSON
        + api_io_events() : JSON
    }
}

package "Core Engine" #F0FDF4 {
    class SystemMonitor <<Service>> {
        - sampling_interval : float
        - window_size : int
        - io_window_size : int
        - hpc_buffer : dict<str, deque>
        - io_buffer : dict<str, deque>
        - model : sklearn.BaseEstimator
        - scaler : StandardScaler
        - model_info : dict
        - model_loaded : bool
        - is_monitoring : bool
        - detection_history : list
        __
        + collect_sample() : tuple
        + compute_features() : dict
        + predict(features: dict) : tuple
        + get_system_status() : dict
        + run_detection_cycle() : dict
        - _identify_threat() : dict
    }
}

package "ML Pipeline" #FEF3C7 {
    class MLModels <<Service>> {
        {static} + get_feature_columns(model_type: str) : list
        {static} + prepare_data(dataset, model_type, ...) : tuple
        {static} + get_classifier(name: str) : Classifier
        {static} + evaluate_model(y_true, y_pred, y_prob) : dict
        {static} + compute_time_to_detect(model, ...) : list
        {static} + train_all_models(dataset: DataFrame) : tuple
        {static} + train_and_save() : dict
    }

    class DataGenerator <<Utility>> {
        {static} + generate_hpc_raw_samples(app_type, workload, n) : dict
        {static} + generate_io_raw_samples(app_type, workload, n) : dict
        {static} + compute_statistical_features(raw: dict) : dict
        {static} + generate_trace(app_name, app_type, ...) : DataFrame
        {static} + generate_dataset(num_rounds: int) : DataFrame
    }
}

package "Configuration" #F5F3FF {
    class Config <<Singleton>> {
        + BASE_DIR : str
        + DATA_DIR : str
        + MODEL_DIR : str
        + STATIC_DIR : str
        + TEMPLATE_DIR : str
        + HPC_EVENTS : list
        + IO_EVENTS : list
        + STAT_FEATURES : list
        + CLASSIFIERS : list
        + RANSOMWARE_FAMILIES : dict
        + BENIGN_APPS : list
        + FLASK_HOST : str
        + FLASK_PORT : int
    }
}

package "Threat Simulation" #FEE2E2 {
    class DummyThreat <<TestUtility>> {
        {static} + simulate_io_spike() : void
    }
}

' ── Relationships ──
FlaskApp "1" *-- "1" SystemMonitor : owns >
FlaskApp ..> MLModels : <<uses>> triggers training
FlaskApp ..> DataGenerator : <<uses>> generates data
SystemMonitor --> MLModels : loads trained model
MLModels --> DataGenerator : requests dataset
MLModels ..> Config : reads configuration
SystemMonitor ..> Config : reads configuration
DataGenerator ..> Config : reads configuration
DummyThreat ..> SystemMonitor : simulates threat for

note right of FlaskApp
  Entry point: <b>app.py</b>
  Serves REST API + HTML templates
  via Flask on port 5000
end note

note bottom of SystemMonitor
  Uses <b>psutil</b> for real-time
  CPU & Disk I/O metrics collection.
  Maps hardware counters to
  HPC event features.
end note

@enduml


