' ============================================================================
' ██  6. SEQUENCE DIAGRAM — Behavioral
' ============================================================================
@startuml SequenceDiagram
!theme cerulean-outline
skinparam backgroundColor #FAFAFA
skinparam sequenceMessageAlign center
skinparam sequenceArrowThickness 2
skinparam participantPadding 12
skinparam shadowing true
skinparam roundCorner 10

title <b>Sequence Diagram</b>\nReal-Time Ransomware Detection Flow

actor "User" as user
participant "Browser\n//dashboard.js//" as browser #E0F2FE
participant "Flask API\n//app.py//" as api #F0FDF4
participant "SystemMonitor\n//monitor.py//" as monitor #FEF3C7
participant "psutil\n//OS Layer//" as psutil #F5F3FF
participant "ML Model\n//RandomForest//" as model #FEE2E2

== Periodic Monitoring Loop (every 2s) ==

user -> browser : Open Dashboard
activate browser

loop Every 2 seconds
    browser -> api : GET /api/detect
    activate api

    api -> monitor : run_detection_cycle()
    activate monitor

    monitor -> psutil : cpu_percent(), cpu_times(),\ncpu_stats(), cpu_freq()
    activate psutil
    psutil --> monitor : CPU metrics
    deactivate psutil

    monitor -> psutil : disk_io_counters()
    activate psutil
    psutil --> monitor : Disk I/O metrics
    deactivate psutil

    monitor -> monitor : Map metrics → HPC/IO events\ncompute_features()

    monitor -> model : predict(features)
    activate model
    model -> model : scaler.transform(X)
    model -> model : predict_proba(X_scaled)
    model --> monitor : (prediction=1, probability=0.92)
    deactivate model

    alt prediction == 1 (Ransomware Detected!)
        monitor -> psutil : process_iter()\nscan all processes
        activate psutil
        psutil --> monitor : process list
        deactivate psutil
        monitor -> monitor : _identify_threat()\nrank by CPU/IO
        monitor --> api : {is_ransomware: true,\nthreat_info: {...}}
    else prediction == 0 (Benign)
        monitor --> api : {is_ransomware: false}
    end

    deactivate monitor
    api --> browser : JSON response
    deactivate api
    browser -> browser : Update UI charts,\nshow alert if threat
end

== Kill Process Flow ==

user -> browser : Click "Stop Threat"
browser -> api : POST /api/kill-process\n{pid: 4832}
activate api
api -> api : Validate PID\nCheck protected list\nCheck ownership
api -> psutil : Process.terminate()
psutil --> api : OK
api --> browser : {success: true}
deactivate api
browser --> user : ✔ Process terminated

@enduml


